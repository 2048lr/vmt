{
  "$schema": "https://json-schema.org/draft-07/schema",
  "source": "package.json",
  "historyFile": ".version-history.json",
  "port": 3000,
  "host": "127.0.0.1",
  "files": [
    {
      "path": "package.json",
      "type": "json",
      "field": "version"
    },
    {
      "path": "package-lock.json",
      "type": "json-root",
      "field": "version"
    },
    {
      "path": "README.md",
      "type": "markdown",
      "pattern": "version[:\\s-]*`?(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)[^\\s`]*`?"
    },
    {
      "path": "src/version.js",
      "type": "text",
      "pattern": "VERSION\\s*=\\s*['\"]([^'\"]+)['\"]"
    }
  ]
}
